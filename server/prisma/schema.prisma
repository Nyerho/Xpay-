generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  CONSUMER
  SUPPORT
  FINANCE
  ADMIN
  SUPERADMIN
}

enum KycStatus {
  PENDING
  APPROVED
  REJECTED
  MANUAL_REVIEW
}

enum GiftCardStatus {
  REVIEWING
  APPROVED
  REJECTED
}

enum InventoryStatus {
  AVAILABLE
  SOLD
  VOID
}

enum TxStatus {
  PENDING
  COMPLETE
  FAILED
  REFUNDED
}

enum TxType {
  CRYPTO_BUY
  CRYPTO_SELL
  SWAP
  CONVERT
  GIFT_CARD_SELL
  GIFT_CARD_BUY
  BILL_PAY
  WITHDRAWAL
  DEPOSIT
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  phone        String?
  passwordHash String
  role         Role     @default(CONSUMER)
  isFrozen     Boolean  @default(false)
  mfaEnabled   Boolean  @default(false)
  referralCode String?  @unique
  referredById String?
  referredBy   User?    @relation("UserReferrals", fields: [referredById], references: [id], onDelete: SetNull)
  referrals    User[]   @relation("UserReferrals")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  lastLoginAt  DateTime?

  balance              Balance?
  kycCases             KycCase[]
  giftCardSubmissions  GiftCardSubmission[]
  inventoryPurchases   InventoryItem[]     @relation("InventoryPurchasedBy")
  transactions         Transaction[]
  auditLogsAsActor     AuditLog[]          @relation("AuditActor")
  giftCardsReviewed    GiftCardSubmission[] @relation("GiftCardReviewedBy")
  kycReviewed          KycCase[]           @relation("KycReviewedBy")
  externalWallets      ExternalWallet[]
  notifications        Notification[]
  promoRedemptions     PromoRedemption[]
  referralRedemptionsAsReferred ReferralRedemption[] @relation("ReferralReferred")
  referralRedemptionsAsReferrer ReferralRedemption[] @relation("ReferralReferrer")
}

model Balance {
  userId   String   @id
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  usdCents  Int @default(0)
  ngnKobo   Int @default(0)
  usdtCents Int @default(0)
  btcSats   Int @default(0)
  ethWei    String @default("0")

  updatedAt DateTime @updatedAt
}

model KycCase {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  status       KycStatus @default(PENDING)
  providerRef  String?
  ssn4         String?
  dob          String?
  selfieUrl    String?
  reviewedById String?
  reviewedBy   User?     @relation("KycReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewNotes  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GiftCardSubmission {
  id           String        @id @default(cuid())
  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  brand        String
  valueUsdCents Int
  offerUsdtCents Int
  status       GiftCardStatus @default(REVIEWING)
  frontImageUrl String?
  backImageUrl  String?
  ocrCode      String?
  fraudFlagsJson String @default("[]")
  reviewedById String?
  reviewedBy   User?         @relation("GiftCardReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewNotes  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model InventoryItem {
  id            String          @id @default(cuid())
  brand         String
  valueUsdCents Int
  code          String
  status        InventoryStatus @default(AVAILABLE)
  purchasedById String?
  purchasedBy   User?           @relation("InventoryPurchasedBy", fields: [purchasedById], references: [id], onDelete: SetNull)
  purchasedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Transaction {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type          TxType
  status        TxStatus @default(PENDING)
  asset         String?
  amountUsdCents Int?
  amountAssetMinor Int?
  externalRef   String?  @unique
  metadataJson  String   @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Setting {
  key        String   @id
  valueJson  String
  updatedAt  DateTime @updatedAt
  updatedById String?
}

model ExternalWallet {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider  String
  walletId  String
  blockchain String
  address   String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([provider, walletId])
  @@unique([userId, provider, blockchain])
}

model ExternalWebhookEvent {
  id        String   @id @default(cuid())
  provider  String
  eventId   String
  payloadJson String
  createdAt DateTime @default(now())

  @@unique([provider, eventId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  type      String
  title     String
  body      String
  link      String?
  isRead    Boolean  @default(false)

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model PromoCode {
  id            String   @id @default(cuid())
  code          String   @unique
  ngnBonusKobo  Int      @default(0)
  maxRedemptions Int?
  redeemedCount Int      @default(0)
  isActive      Boolean  @default(true)
  expiresAt     DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  redemptions   PromoRedemption[]
}

model PromoRedemption {
  id          String   @id @default(cuid())
  promoCodeId String
  promoCode   PromoCode @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  appliedAt   DateTime?
  appliedTxId String?

  @@unique([promoCodeId, userId])
  @@index([userId, createdAt])
}

model ReferralRedemption {
  id             String   @id @default(cuid())
  referredUserId String   @unique
  referredUser   User     @relation("ReferralReferred", fields: [referredUserId], references: [id], onDelete: Cascade)
  referrerUserId String
  referrerUser   User     @relation("ReferralReferrer", fields: [referrerUserId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  appliedAt      DateTime?
  depositTxId    String?

  @@index([referrerUserId, createdAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actor      User?    @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  action     String
  entity     String
  entityId   String?
  beforeJson String?
  afterJson  String?
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())
}
